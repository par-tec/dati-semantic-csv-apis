      "@value": Vocabolario controllato sulla tipologia del servizio di una nave
        adottata dall'INAIL
      "@language": it
    description:
      - "@value": Servizio a cui una nave può essere abilitata
        "@language": it
      - "@value": Service to which a ship may be enabled
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: servizio_nave
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/proc21_self_liquidation/specie_navigazione
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario controllato sulla specie di navigazione della nave
        adottata dall'INAIL
      "@language": it
    description:
      - "@value": "Specie di navigazione cui può essere abilitata una nave "
        "@language": it

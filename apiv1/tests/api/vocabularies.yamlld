"@graph":
  - "@id": https://w3id.org/italia/controlled-vocabulary/classifications-for-organizations/ateco-2007
    versionInfo:
      "@value": versione 2007 - aggiornamento 2021
      "@language": it
    prefLabel:
      - Classificazione Ateco 2007 - Aggiornamento 2021
      - "@value": Classificazione Ateco 2007 - Aggiornamento 2021
        "@language": it
    description:
      "@value": Classificazione ISTAT Ateco 2007 - Aggiornamento 2021; la
        classificazione è usata per catalogare le attività economiche. E' la
        classificazione di riferimento per il Registro Imprese
      "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/data/public-organization/ISTAT
    type: http://purl.org/adms/assettype/Taxonomy
    keyConcept: ateco-2007
  - "@id": https://w3id.org/italia/social-security/controlled-vocabulary/contributions/tipo_gestione_ricongiunzione
    versionInfo: "0.4"
    prefLabel:
      "@value": Vocabolario Controllato sul tipo di gestione di una pratica di
        ricongiunzione adottato dall'INPS
      "@language": it
    description:
      - "@value": Indica la cassa o il fondo pensionistico in cui il datore di lavoro ha
          versato i contributi
        "@language": it
      - "@value": Pension fund in which the employer paid contributions
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/social-security/data/organization/inps
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_gestione_ricongiunzione
  - "@id": https://w3id.org/italia/social-security/controlled-vocabulary/contributions/tipo_ricongiunzione
    versionInfo: "0.4"
    prefLabel:
      "@value": Vocabolario Controllato sul tipo di ricongiunzione adottato dall'INPS
      "@language": it
    description:
      - "@value": Indica il tipo di ricongiunzione che consente, a chi ha posizioni
          assicurative in gestioni previdenziali diverse, di riunire, mediante
          trasferimento, tutti i periodi contributivi presso un’unica gestione,
          allo scopo di ottenere una sola pensione
        "@language": it
      - "@value": Aggregation type that allows, for those who have insurance positions
          in different social security managements, to combine, by transfer, all
          the contribution periods in a single management, in order to obtain a
          single pension
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/social-security/data/organization/inps
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_ricongiunzione
  - "@id": https://w3id.org/italia/social-security/controlled-vocabulary/contributions/tipo_gestione_riscatto
    versionInfo: "0.4"
    prefLabel:
      "@value": Vocabolario Controllato sul tipo di gestione di una pratica di
        riscatto adottato dall'INPS
      "@language": it
    description:
      - "@value": Indica il tipo di gestione in cui si intende riscattare il periodo
        "@language": it
      - "@value": Type of management in which the period is to be redeemed
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/social-security/data/organization/inps
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_gestione_riscatto
  - "@id": https://w3id.org/italia/social-security/controlled-vocabulary/contributions/tipo_riscatto_privato
    versionInfo: "0.4"
    prefLabel:
      "@value": Vocabolario Controllato sul tipo di riscatto per la gestione privata
        adottato dall'INPS
      "@language": it
    description:
      - "@value": Redemption type for private management that allows contributory
          recognition for specific periods otherwise without contributions
        "@language": en
      - "@value": Indica il tipo di riscatto per la gestione privata che consente il
          riconoscimento contributivo per specifici periodi altrimenti privi di
          contribuzione
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/social-security/data/organization/inps
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_riscatto_privato
  - "@id": https://w3id.org/italia/social-security/controlled-vocabulary/contributions/tipo_riscatto_pubblico
    versionInfo: "0.4"
    prefLabel:
      "@value": Vocabolario Controllato sul tipo di riscatto per la gestione pubblica
        adottato dall'INPS
      "@language": it
    description:
      - "@value": Redemption type for public management that allows contributory
          recognition for specific periods otherwise without contributions
        "@language": en
      - "@value": Indica il tipo di riscatto per la gestione pubblica che consente il
          riconoscimento contributivo per specifici periodi altrimenti privi di
          contribuzione
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/social-security/data/organization/inps
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_riscatto_pubblico
  - "@id": https://w3id.org/italia/social-security/controlled-vocabulary/domesticWorkServices/tipo_mansione_lavoratore_domestico
    versionInfo: "0.1"
    prefLabel:
      "@value": Vocabolario controllato sulla tipologia di mansione svolta dal
        Lavoratore Domestico
      "@language": it
    description:
      - "@value": Vocabolario controllato sulla tipologia di retribuzione
        "@language": it
      - "@value": Controlled vocabulary on remuneration type
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/social-security/data/organization/inps
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_mansione_lavoratore_domestico
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/classe_menomazione
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classe di menomazione adottata dall'INAIL
      "@language": it
    description:
      - "@value": "Classificazione rispetto agli intervalli di variabilità del grado di
          menomazione. Sono state definite convenzionalmente 3 classi: [1-5%],
          [6-15%]; [16-100%]"
        "@language": it
      - "@value": "Classification with respect to the ranges of variability of the
          menomation grade. Three classes have been conventionally defined:
          [1-5%], [6-15%]; [16-100%]"
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: classe_menomazione
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/inabilita
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione del grado di inabilità
        adottata dall'INAIL
      "@language": it
    description:
      - "@value": Percentuale con cui si misura il livello di perdita della capacità
          lavorativa complessiva in conseguenza di infortunio sul lavoro o di
          malattia professionale in regime Testo Unico.
        "@language": it
      - "@value": Percentage by which the level of loss of global work capacity as a
          result of occupational injury or occupational disease is measured
          under the Unique Text regime.
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: grado_inabilita
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/tipo_trattazione
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla tipologia di trattazione adottata
        dall'INAIL
      "@language": it
    description:
      - "@value": Tipologie delle trattazioni che, a seguito dell'istruttoria,
          determinano il periodo di inabilità assoluta al lavoro, il grado di
          invalidità/menomazione, l’indennizzo e la prestazione che viene
          erogata agli aventi diritto.
        "@language": it
      - "@value": Types of processing that, as a result of the investigation, determine
          the period of absolute inability to work, degree of
          inability/disability, compensation and the benefit that is provided to
          the eligible
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_trattazione
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/causa_esterna
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario controllato sulla classificazione delle cause esterne
        adottata dall'INAIL
      "@language": it
    description:
      - "@value": Additional classification of external causes of traumatism and
          poisoning
        "@language": en
      - "@value": Classificazione supplementare delle cause esterne di traumatismo ed
          avvelenamento
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: classificazione_cause_esterne
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/classificazione_ICDX
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla Classificazione Internazionale delle
        Malattie decima edizione (ICDX)
      "@language": it
    description:
      - "@value": Decoding of the definition of the disease according to the
          International Classification of Diseases (ICD10).
        "@language": en
      - "@value": Decodifica della definizione della malattia secondo la Classificazione
          Internazionale delle Malattie (ICD10).
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: classificazione_ICDX
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/tipo_malattia
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione delle tipologie di
        malattia adottata dall'INAIL
      "@language": it
    description:
      - "@value": Classification of occupational diseases
        "@language": en
      - "@value": Anagrafica delle malattie professionali
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_malattia
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/tipo_tecnopatia
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione del tipo di tecnopatia
        adottata dall'INAIL
      "@language": it
    description:
      - "@value": Classification of the type of occupational disease
        "@language": en
      - "@value": Classificazione del tipo di malattia professionale
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_tecnopatia
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/decisione_istruttoria_esito_mortale
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione dell'istruttoria esito
        mortale adottata dall'INAIL
      "@language": it
    description:
      - "@value": Controlled vocabulary that identifies the type of investigation in the
          event of a fatal outcome
        "@language": en
      - "@value": Vocabolario controllato che identifica la tipologia di decisione
          istruttoria in caso di esito mortale
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: decisione_istruttoria_esito_mortale
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/tipo_definizione_decisione_istruttoria
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sul tipo definizione decisione
        dell'istruttoria adottato dall'INAIL
      "@language": it
    description:
      - "@value": Descrizione della definizione della trattazione o della riapertura
          della pratica di infortunio o malattia professionale.
        "@language": it
      - "@value": Description of the definition of the treatment or reopening of the
          occupational injury or occupational disease
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_definizione_decisione_istruttoria
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/definizione_amministrativa
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione della definizione
        amministrativa adottata dall'INAIL
      "@language": it
    description:
      - "@value": "Definition of Occupational Disease/Occupational Injury: Positive,
          Negative, Deductible, in Investigation"
        "@language": en
      - "@value": "Definizione della Malattia Professionale/Infortunio: Positivo,
          Negativo, Franchigia, In Istruttoria"
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: definizione_amministrativa
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/grande_gruppo_tariffario
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione del grande gruppo
        tariffario adottata dall'INAIL
      "@language": it
    description:
      - "@value": Large group of activities referring to the same tariff management;
          each large group brings together a set of processing that belong to
          homogeneous production sectors
        "@language": en
      - "@value": Grande gruppo di attività riferite ad una stessa gestione tariffaria;
          ogni grande gruppo raccoglie un insieme di lavorazioni che
          appartengono a comparti produttivi omogenei
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: grande_gruppo_tariffario
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/mansione
    versionInfo: "0.6"
    prefLabel:
      "@value": Mansionario adottato dall'INAIL
      "@language": it
    description:
      - "@value": Six-level classification of the works that injured person/worker with
          occupational disease performs at the time of the work accident
        "@language": en
      - "@value": Classificazione a sei livelli delle professioni che
          l'infortunato/tecnopatico svolge al momento dell'accadimento
          dell'evento lesivo.
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: mansione
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/settore_correlato_malattia
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione del settore correlato
        malattia adottata dall'INAIL
      "@language": it
    description:
      - "@value": Grouping of sectors and subsectors of CNEL employment contracts.
        "@language": en
      - "@value": Raggruppamento settori e sottosettori contratti di lavoro CNEL.
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: settore_correlato_malattia
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/tipo_lavoratore
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario controllato sulla classificazione del tipo di lavoratore
        adottata dall'INAIL
      "@language": it
    description:
      - "@value": List of worker types referred to the type of employer in the sectors
          of industry, handicrafts, services and public administrations holding
          P.A.T
        "@language": en
      - "@value": Elenco delle tipologie di lavoratore riferite alla tipologia di datore
          di lavoro dei settori industria, artigianato, servizi e Pubbliche
          Amministrazioni titolari di P.A.T.
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_lavoratore
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/tipo_lavoro
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla classificazione delle tipologie di
        lavoro adottata dall'INAIL
      "@language": it
    description:
      - "@value": Classification of the types of work performed by the injured/worker
          with occupational disease
        "@language": en
      - "@value": Classificazione delle tipologie di lavoro svolte
          dall'infortunato/tecnopatico
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_lavoro
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/attivita_fisica
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulle tipologie di attività fisica adottate
        dall'INAIL
      "@language": it
    description:
      - "@value": Classificazione a due livelli dell'attività svolta al momento
          dell'evento lesivo
        "@language": it
      - "@value": Two-level classification of the activity carried out at the time of
          work accident
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_attivita_fisica
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/luogo_accadimento
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario Controllato sulla tipologia dei luoghi di accadimento
        adottata dall'INAIL
      "@language": it
    description:
      - "@value": "Classification of places where the work accident happened "
        "@language": en
      - "@value": Classificazione dei luoghi in cui è avvenuto l'evento lesivo
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: tipo_luogo_accadimento
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/natura_lesione
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario controllato sulla classificazione della natura della
        lesione adottata dall'INAIL
      "@language": it
    description:
      - "@value": Tipologia della lesione causata da un evento lesivo e classificata in
          10 categorie.
        "@language": it
      - "@value": Type of injury caused by a work accident and classified into 10
          categories.
        "@language": en
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: natura_lesione
  - "@id": https://w3id.org/italia/work-accident/controlled-vocabulary/adm_serv/sede_lesione
    versionInfo: "0.6"
    prefLabel:
      "@value": Vocabolario controllato sulla sede della lesione adottata da INAIL
      "@language": it
    description:
      - "@value": Classification of the parts of the body where the lesion is located
        "@language": en
      - "@value": Classificazione delle parti del corpo sede della lesione
        "@language": it
    language: http://publications.europa.eu/resource/authority/language/ITA
    rightsHolder: https://w3id.org/italia/work-accident/data/organization/inail
    type: http://purl.org/adms/assettype/CodeList
    keyConcept: sede_lesione
